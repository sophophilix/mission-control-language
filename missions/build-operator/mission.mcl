// Build Operator Design — progressive architectural review
// Produces a production-grade Kubernetes operator design reviewed through
// three lenses: architecture, security, and principal engineering.

use "./experts"

// LLM provider — override via MCL_PROVIDER, MCL_API_KEY, MCL_MODEL, MCL_ENDPOINT
let provider = env("MCL_PROVIDER", "openai")
let apiKey   = env("MCL_API_KEY")
let model    = env("MCL_MODEL", "gpt-4o-mini")

// Mission inputs
let goal     = "Design a production-grade K8s build operator"
let persona  = "Principal SRE, Tekton specialist"

mission BuildOperatorDesign(goal, persona) =
    KubernetesArchitect             // drafts CRDs, controller structure, RBAC
    |> SecurityArchitect            // hardens the design
    |> PrincipalReviewer with { style = "terse ADR" }  // final sign-off as a terse ADR
