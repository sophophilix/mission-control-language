// Rule gate demo — deterministic check integrated with loop convergence
// Drafter writes content; WordCountGate enforces a minimum length.
// If the gate fails it writes its onFail message to {{feedback}},
// which the Drafter sees on the next attempt.

let topic = "the difference between concurrency and parallelism"

mission DraftWithLengthGate(topic) loop(3) = {
    Drafter
    -> WordCountGate
}

output(DraftWithLengthGate)
