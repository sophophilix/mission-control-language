// Elevator pitch — single-shot pitch writer
// One expert, one pass. Compare with elevator-pitch-refined for
// the difference expert composition makes.

use "./experts"

// LLM provider — override via MCL_PROVIDER, MCL_API_KEY, MCL_MODEL, MCL_ENDPOINT
let provider = env("MCL_PROVIDER", "openai")
let apiKey   = env("MCL_API_KEY")
let model    = env("MCL_MODEL", "gpt-4o-mini")

let product  = "an app that turns voice memos into structured tasks"

mission QuickPitch(product) =
    PitchWriter  // single expert, single pass

output(QuickPitch)
