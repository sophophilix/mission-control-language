// Loop demo — reliable answer via retry
// ContextOverloaded produces a deliberately vague answer.
// QualityJudge evaluates it and fails if it lacks precision.
// The pipeline retries up to 3 times until the judge passes.

use "./experts"

// LLM provider — override via MCL_PROVIDER, MCL_API_KEY, MCL_MODEL, MCL_ENDPOINT
let provider = env("MCL_PROVIDER", "openai")
let apiKey   = env("MCL_API_KEY")
let model    = env("MCL_MODEL", "gpt-4o-mini")

let topic    = "why the sky is blue"

mission DemoReliability(topic) =
    ContextOverloaded   // produces a vague, overconfident answer
    |> QualityJudge     // fails if the answer lacks a named mechanism
    loop 3              // retry up to 3 times until judge passes

output(DemoReliability)
