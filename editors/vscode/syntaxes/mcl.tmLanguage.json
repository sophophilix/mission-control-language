{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "MCL",
    "scopeName": "source.mcl",
    "fileTypes": ["mcl"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#keyword" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#operator" },
        { "include": "#expert-name" },
        { "include": "#identifier" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comment": {
            "name": "comment.line.double-slash.mcl",
            "match": "//.*$"
        },
        "keyword": {
            "name": "keyword.control.mcl",
            "match": "\\b(mission|let|loop|using|when|else|parallel|env|output)\\b"
        },
        "string": {
            "name": "string.quoted.double.mcl",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "keyword.other.placeholder.mcl",
                    "match": "\\{\\{[^}]+\\}\\}"
                }
            ]
        },
        "number": {
            "name": "constant.numeric.mcl",
            "match": "\\b[0-9]+\\b"
        },
        "operator": {
            "name": "keyword.operator.mcl",
            "match": "(->|=)"
        },
        "expert-name": {
            "name": "entity.name.class.mcl",
            "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        },
        "identifier": {
            "name": "variable.other.mcl",
            "match": "\\b[a-z][a-zA-Z0-9]*\\b"
        },
        "punctuation": {
            "name": "punctuation.section.mcl",
            "match": "[{}(),:;]"
        }
    }
}
