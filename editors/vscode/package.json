{
    "name": "forge-mcl",
    "displayName": "MCL — Mission Control Language",
    "description": "Syntax highlighting for .mcl mission files",
    "version": "0.1.0",
    "publisher": "forgelang",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/katasec/mission-control-language"
    },
    "license": "MIT",
    "contributes": {
        "languages": [
            {
                "id": "mcl",
                "aliases": ["MCL", "Mission Control Language"],
                "extensions": [".mcl"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "mcl",
                "scopeName": "source.mcl",
                "path": "./syntaxes/mcl.tmLanguage.json"
            }
        ]
    }
}
